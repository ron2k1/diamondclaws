# DiamondClaws — OpenClaw Gateway Frontend
# Get your API key from https://openrouter.ai/

# Required - Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-

# Server
HOST=0.0.0.0
PORT=8000

# OpenClaw gateway (optional — auto-detected on localhost:18789)
# OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
# OPENCLAW_GATEWAY_TOKEN=your-token-here

# Database path (default: data/diamondclaws.db)
# DIAMONDCLAWS_DB=data/diamondclaws.db

# Model — agents use whatever model is configured in ~/.openclaw/openclaw.json
# Change agent models via: openclaw agents update <id> --model <provider/model>
