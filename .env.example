# DiamondClaws — OpenClaw Gateway Wrapper
# All LLM calls go through OpenClaw. API keys are managed there.
# Run: openclaw configure --section model

# ── Server ───────────────────────────────────────────────────────────

HOST=0.0.0.0
PORT=8000

# ── OpenClaw Gateway (required) ─────────────────────────────────────

# The gateway must be running for DiamondClaws to function.
# Start it with: openclaw gateway start
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# ── Autonomous Monitor (opt-in) ─────────────────────────────────────

# Enable background stock monitoring
# MONITOR_ENABLED=true

# Poll interval in seconds (default: 120)
# POLL_INTERVAL_SECONDS=120

# How many of 4 bullish indicators must agree (default: 3)
# SIGNAL_THRESHOLD=3

# Per-ticker cooldown after trigger in seconds (default: 900 = 15 min)
# COOLDOWN_SECONDS=900
