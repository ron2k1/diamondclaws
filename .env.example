# DiamondClaws — Multi-Provider AI Gateway
# Fill in API keys for whichever providers you want to use.
# You only need ONE provider to get started. OpenRouter gives access to all models.

# ── Provider API Keys ────────────────────────────────────────────────

# OpenRouter (universal — one key, 200+ models)
# Get your key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenAI (GPT-4.1, GPT-4.1 Mini)
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google (Gemini 2.0 Flash, Gemini 2.5 Pro)
# Get your key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Anthropic (Claude Sonnet 4, Claude 3.5 Haiku)
# Get your key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# DeepSeek (DeepSeek V3, DeepSeek R1)
# Get your key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# xAI (Grok 3 Mini)
# Get your key: https://console.x.ai/
XAI_API_KEY=

# Mistral (Mistral Large)
# Get your key: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# ── Server ───────────────────────────────────────────────────────────

HOST=0.0.0.0
PORT=8000

# ── Optional ─────────────────────────────────────────────────────────

# OpenClaw gateway (auto-detected on localhost:18789)
# OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# Database path (default: data/diamondclaws.db)
# DIAMONDCLAWS_DB=data/diamondclaws.db
